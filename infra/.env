# ============================================
# RAG Chatbot - Environment Variables
# ============================================

# --- OpenSearch ---
RAG_OPENSEARCH_HOST=opensearch
RAG_OPENSEARCH_PORT=9200
RAG_OPENSEARCH_SCHEME=http
RAG_OPENSEARCH_USERNAME=admin
RAG_OPENSEARCH_PASSWORD=OpenSearch@Admin#2024X

# --- PostgreSQL (Database) ---
DATABASE_URL=postgresql+asyncpg://admin:secret@postgresql:5432/chatbot

# --- Redis (Session/Cache) ---
REDIS_URL=redis://redis:6379

# --- LLM (LMStudio - OpenAI Compatible) ---
# host.docker.internal is used in Docker to access host machine services
LMSTUDIO_URL=http://host.docker.internal:1234/v1
LLM_MODEL=lmstudio-community

# --- RAG Settings ---
RAG_EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDING_DIM=768
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_MIN_CHUNK_SIZE=100
RAG_SEARCH_TOP_K=100
RAG_RERANK_TOP_N=5
RAG_RRF_K=60
RAG_CROSS_ENCODER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RAG_QUERY_REWRITE_ENABLED=true
RAG_NUM_REWRITTEN_QUERIES=3
RAG_LLM_BASE_URL=http://127.0.0.1:1234/v1
RAG_LLM_MODEL=lmstudio-community
RAG_LLM_TEMPERATURE=0.7
RAG_LLM_MAX_TOKENS=2000

# --- PostgreSQL (Docker) ---
POSTGRES_DB=chatbot
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
